{
    "bootloader": "Systemd-boot",
    "custom-commands": [
        "curl --location --output /paru.tar.zst https://github.com/morganamilo/paru/releases/download/v2.0.3/paru-v2.0.3-1-x86_64.tar.zst",
        "tar --directory / --extract --file /paru.tar.zst --zstd paru",
        "sed --expression 's/ALL$/NOPASSWD: ALL/' --in-place /etc/sudoers.d/00_jcardoso",
        "su jcardoso --command '/paru --noconfirm --sync k3s-bin paru-bin'",
        "mkdir /etc/systemd/system/k3s.service.d",
        "echo -e '[Service]\nExecStart=\nExecStart=/usr/bin/k3s server --disable traefik --disable-helm-controller --node-label intel.feature.node.kubernetes.io/gpu=true --tls-san intel-nuc.fable-blues.ts.net' > /etc/systemd/system/k3s.service.d/override.conf",
        "systemctl enable k3s",
        "sed --expression 's/NOPASSWD: //' --in-place /etc/sudoers.d/00_jcardoso",
        "rm --force --recursive /lost+found /paru /paru.tar.zst"
    ],
    "disk_config": {
        "config_type": "manual_partitioning",
        "device_modifications": [
            {
                "device": "/dev/nvme0n1",
                "partitions": [
                    {
                        "dev_path": null,
                        "flags": [
                            "Boot",
                            "ESP"
                        ],
                        "fs_type": "fat32",
                        "mount_options": [],
                        "mountpoint": "/boot",
                        "obj_id": "boot",
                        "size": {
                            "sector_size": {
                                "unit": "B",
                                "value": 512
                            },
                            "unit": "MB",
                            "value": 1024
                        },
                        "start": {
                            "sector_size": {
                                "unit": "B",
                                "value": 512
                            },
                            "unit": "MB",
                            "value": 8
                        },
                        "status": "create",
                        "type": "primary"
                    },
                    {
                        "dev_path": null,
                        "fs_type": "ext4",
                        "mount_options": [],
                        "mountpoint": "/",
                        "obj_id": "root",
                        "size": {
                            "sector_size": {
                                "unit": "B",
                                "value": 512
                            },
                            "unit": "GB",
                            "value": 1800
                        },
                        "start": {
                            "sector_size": {
                                "unit": "B",
                                "value": 512
                            },
                            "unit": "MB",
                            "value": 1040
                        },
                        "status": "create",
                        "type": "primary"
                    }
                ],
                "wipe": true
            }
        ]
    },
    "hostname": "intel-nuc",
    "kernels": [
        "linux"
    ],
    "locale_config": {
        "kb_layout": "uk",
        "sys_enc": "UTF-8",
        "sys_lang": "en_GB"
    },
    "mirror_config": {
        "mirror_regions": {
            "United Kingdom": [
                "https://mirror.bytemark.co.uk/archlinux/$repo/os/$arch"
            ]
        }
    },
    "network_config": {
        "nics": [
            {
                "dhcp": true,
                "dns": [],
                "gateway": null,
                "iface": "eno1",
                "ip": null
            }
        ],
        "type": "manual"
    },
    "ntp": true,
    "packages": [
        "git",
        "k9s",
        "open-iscsi",
        "openssh",
        "tailscale"
    ],
    "services": [
        "sshd",
        "tailscaled"
    ],
    "swap": false,
    "timezone": "Europe/London"
}
